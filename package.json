{
  "name": "transparent-fit",
  "version": "1.0.0",
  "private": true,
  "description": "Camera app showing transparent garment outline on body in real time. iOS + Android.",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "pods": "cd ios && pod install && cd ..",
    "clean:ios": "cd ios && rm -rf build Pods Podfile.lock && pod install && cd ..",
    "clean:android": "cd android && ./gradlew clean && cd ..",
    "postinstall": "[ \"$CI\" = \"true\" ] || ([ \"$(uname)\" = \"Darwin\" ] && (cd ios && pod install) || true)"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.74.5",
    "react-native-vision-camera": "^4.5.2",
    "@shopify/react-native-skia": "^1.5.0",
    "react-native-reanimated": "^3.15.0",
    "react-native-safe-area-context": "^4.11.0",
    "react-native-svg": "^15.6.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-image-picker": "^7.1.2",
    "react-native-fs": "^2.20.0",
    "@react-native-camera-roll/camera-roll": "^7.8.3",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "react-native-haptic-feedback": "^2.3.3",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "0.74.87",
    "@react-native/eslint-config": "0.74.87",
    "@react-native/metro-config": "0.74.87",
    "@react-native/typescript-config": "0.74.87",
    "@types/jest": "^29.5.13",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "18.3.1",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  },
  "jest": {
    "preset": "react-native",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/ios/",
      "/android/"
    ]
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
